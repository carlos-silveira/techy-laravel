{
    "openapi": "3.1.0",
    "info": {
        "title": "Laravel",
        "version": "0.0.1"
    },
    "servers": [
        {
            "url": "http://localhost/api"
        }
    ],
    "paths": {
        "/user": {
            "get": {
                "responses": {
                    "200": {
                        "description": "`User`",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "$ref": "#/components/schemas/User"
                                }
                            }
                        }
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    }
                }
            }
        },
        "/generate-brief": {
            "post": {
                "operationId": "ai.generateBrief",
                "summary": "Synthesize article content into an executive brief",
                "tags": [
                    "Ai"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "content": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "content"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "brief": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "brief"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/generate-seo": {
            "post": {
                "operationId": "ai.generateSeoTags",
                "summary": "Generate SEO metadata (description and keywords)",
                "tags": [
                    "Ai"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "content": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "content"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "description": {
                                            "anyOf": [
                                                {},
                                                {
                                                    "type": "string",
                                                    "enum": [
                                                        "Techy News AI Automated Article"
                                                    ]
                                                }
                                            ]
                                        },
                                        "keywords": {
                                            "anyOf": [
                                                {},
                                                {
                                                    "type": "string",
                                                    "enum": [
                                                        "news, tech, ai"
                                                    ]
                                                }
                                            ]
                                        }
                                    },
                                    "required": [
                                        "description",
                                        "keywords"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/generate-image-prompt": {
            "post": {
                "operationId": "ai.generateImagePrompt",
                "summary": "Architect a visual prompt for image generation",
                "tags": [
                    "Ai"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "content": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "content"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "prompt": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "prompt"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/generate-ideas": {
            "get": {
                "operationId": "ai.generateIdeas",
                "summary": "Fetch today's news and generate prompt ideas",
                "tags": [
                    "Ai"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "ideas": {
                                            "type": "array",
                                            "items": {}
                                        }
                                    },
                                    "required": [
                                        "ideas"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/generate-draft": {
            "post": {
                "operationId": "ai.generateDraft",
                "summary": "Auto-draft a full article based on an idea",
                "tags": [
                    "Ai"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "title": {
                                        "type": "string"
                                    },
                                    "prompt": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "title",
                                    "prompt"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "draft": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "draft"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/editor-action": {
            "post": {
                "operationId": "ai.editorAction",
                "summary": "Perform specific context-aware actions in the editor",
                "tags": [
                    "Ai"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "action": {
                                        "type": "string",
                                        "enum": [
                                            "continue",
                                            "summarize",
                                            "professional",
                                            "fix_grammar"
                                        ]
                                    },
                                    "text": {
                                        "type": "string"
                                    }
                                },
                                "required": [
                                    "action",
                                    "text"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "result": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "result"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/studio-chat": {
            "post": {
                "operationId": "ai.studioChat",
                "summary": "Handle multi-turn conversational AI for the Studio",
                "tags": [
                    "Ai"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "message": {
                                        "type": "string"
                                    },
                                    "history": {
                                        "type": [
                                            "array",
                                            "null"
                                        ],
                                        "items": {
                                            "type": "string"
                                        }
                                    },
                                    "editor_context": {
                                        "type": [
                                            "array",
                                            "null"
                                        ],
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                },
                                "required": [
                                    "message"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "response": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "response"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    }
                }
            }
        },
        "/ask-llama": {
            "post": {
                "operationId": "ai.askLlama",
                "summary": "Ask Llama for a generic response based on a prompt",
                "tags": [
                    "Ai"
                ],
                "requestBody": {
                    "required": true,
                    "content": {
                        "application/json": {
                            "schema": {
                                "type": "object",
                                "properties": {
                                    "prompt": {
                                        "type": "string",
                                        "maxLength": 1000
                                    }
                                },
                                "required": [
                                    "prompt"
                                ]
                            }
                        }
                    }
                },
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "response": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "response"
                                    ]
                                }
                            }
                        }
                    },
                    "422": {
                        "$ref": "#/components/responses/ValidationException"
                    },
                    "401": {
                        "$ref": "#/components/responses/AuthenticationException"
                    }
                }
            }
        },
        "/analytics/dashboard": {
            "get": {
                "operationId": "analytics.dashboardStats",
                "summary": "Get aggregate analytics data for the dashboard",
                "tags": [
                    "Analytics"
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "total_views": {
                                            "type": "string"
                                        },
                                        "total_articles": {
                                            "type": "integer",
                                            "minimum": 0
                                        },
                                        "top_articles": {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Article"
                                            }
                                        },
                                        "chart_data": {
                                            "type": "array",
                                            "items": {
                                                "type": "object",
                                                "properties": {
                                                    "name": {
                                                        "type": "string"
                                                    },
                                                    "views": {
                                                        "type": "integer"
                                                    }
                                                },
                                                "required": [
                                                    "name",
                                                    "views"
                                                ]
                                            }
                                        }
                                    },
                                    "required": [
                                        "total_views",
                                        "total_articles",
                                        "top_articles",
                                        "chart_data"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/articles/{id}/like": {
            "post": {
                "operationId": "article.like",
                "summary": "Like an article",
                "tags": [
                    "Article"
                ],
                "parameters": [
                    {
                        "name": "id",
                        "in": "path",
                        "required": true,
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "type": "object",
                                    "properties": {
                                        "likes_count": {
                                            "type": "string"
                                        }
                                    },
                                    "required": [
                                        "likes_count"
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        },
        "/search": {
            "get": {
                "operationId": "public.search",
                "summary": "Search API for Cmd+K floating palette",
                "tags": [
                    "Public"
                ],
                "parameters": [
                    {
                        "name": "q",
                        "in": "query",
                        "schema": {
                            "type": "string"
                        }
                    }
                ],
                "responses": {
                    "200": {
                        "description": "",
                        "content": {
                            "application/json": {
                                "schema": {
                                    "anyOf": [
                                        {
                                            "type": "array",
                                            "items": {
                                                "$ref": "#/components/schemas/Article"
                                            }
                                        },
                                        {
                                            "type": "array",
                                            "items": {
                                                "type": "string"
                                            },
                                            "minItems": 0,
                                            "maxItems": 0,
                                            "additionalItems": false
                                        }
                                    ]
                                }
                            }
                        }
                    }
                }
            }
        }
    },
    "components": {
        "schemas": {
            "Article": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "title": {
                        "type": "string"
                    },
                    "slug": {
                        "type": "string"
                    },
                    "content": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "source_url": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "status": {
                        "type": "string"
                    },
                    "ai_summary": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "created_at": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "format": "date-time"
                    },
                    "views_count": {
                        "type": "integer"
                    },
                    "reading_time_minutes": {
                        "type": [
                            "integer",
                            "null"
                        ]
                    },
                    "meta_description": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "seo_keywords": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "is_editors_choice": {
                        "type": "boolean"
                    },
                    "likes_count": {
                        "type": "integer"
                    },
                    "cover_image_path": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "image_prompt": {
                        "type": [
                            "string",
                            "null"
                        ]
                    },
                    "tags": {
                        "type": [
                            "array",
                            "null"
                        ],
                        "items": {}
                    }
                },
                "required": [
                    "id",
                    "title",
                    "slug",
                    "content",
                    "source_url",
                    "status",
                    "ai_summary",
                    "created_at",
                    "updated_at",
                    "views_count",
                    "reading_time_minutes",
                    "meta_description",
                    "seo_keywords",
                    "is_editors_choice",
                    "likes_count",
                    "cover_image_path",
                    "image_prompt",
                    "tags"
                ],
                "title": "Article"
            },
            "User": {
                "type": "object",
                "properties": {
                    "id": {
                        "type": "integer"
                    },
                    "name": {
                        "type": "string"
                    },
                    "email": {
                        "type": "string"
                    },
                    "email_verified_at": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "format": "date-time"
                    },
                    "created_at": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "format": "date-time"
                    },
                    "updated_at": {
                        "type": [
                            "string",
                            "null"
                        ],
                        "format": "date-time"
                    },
                    "avatar": {
                        "type": [
                            "string",
                            "null"
                        ]
                    }
                },
                "required": [
                    "id",
                    "name",
                    "email",
                    "email_verified_at",
                    "created_at",
                    "updated_at",
                    "avatar"
                ],
                "title": "User"
            }
        },
        "responses": {
            "AuthenticationException": {
                "description": "Unauthenticated",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Error overview."
                                }
                            },
                            "required": [
                                "message"
                            ]
                        }
                    }
                }
            },
            "ValidationException": {
                "description": "Validation error",
                "content": {
                    "application/json": {
                        "schema": {
                            "type": "object",
                            "properties": {
                                "message": {
                                    "type": "string",
                                    "description": "Errors overview."
                                },
                                "errors": {
                                    "type": "object",
                                    "description": "A detailed description of each field that failed validation.",
                                    "additionalProperties": {
                                        "type": "array",
                                        "items": {
                                            "type": "string"
                                        }
                                    }
                                }
                            },
                            "required": [
                                "message",
                                "errors"
                            ]
                        }
                    }
                }
            }
        }
    }
}